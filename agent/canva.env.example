# Canva Connect API credentials
#
# Copiá este archivo a /opt/data/.hermes/secrets/canva.env y reemplazá los valores
# con los reales del deploy Vercel del legacy app:
#   vercel env pull .env.canva.vercel  (desde monet-app)
# o desde el dashboard de Vercel.
#
# CANVA_REFRESH_TOKEN: el long-lived refresh token de la cuenta de servicio.
#   - Si ya tenés uno funcionando en Vercel, copialo.
#   - Si no, en el legacy app: GET /api/canva/bootstrap-bot (después de conectar
#     una vez como Juan Diego en /api/canva/connect) lo imprime.

CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REFRESH_TOKEN=
